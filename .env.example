# BandhanNova API Hunter - Minimal Core Configuration
PORT=8080
ENVIRONMENT=development

# Master Key for encryption/decryption
BANDHANNOVA_MASTER_KEY=your_long_secure_master_key_here

# Global Config Shard (Required to load everything else)
TURSO_GLOBAL_URL=libsql://...
TURSO_GLOBAL_TOKEN=...

# Auth Vars
JWT_SECRET=your_jwt_secret_here

# Optional Infra
REDIS_URL=
PUBLIC_URL=
